[build]
builder = "nixpacks"
buildCommand = "composer install --no-dev --optimize-autoloader && npm ci --production 2>/dev/null; npm run build 2>/dev/null"

[deploy]
startCommand = "php artisan serve --host=0.0.0.0 --port=$PORT"
healthcheckPath = "/up"
healthcheckTimeout = 100

[service]
variablesFromPlugins = ["mysql"]

[[plugins]]
id = "mysql"
