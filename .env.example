APP_NAME=TontineSN
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# 🔑 Remplacez par votre URL de production avant le déploiement.
APP_URL=https://tontinesn.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

# 🔑 Token de déploiement (utilisé par /admin/deploy). Générez avec : openssl rand -hex 32
DEPLOY_TOKEN=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tontine_221
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis

QUEUE_CONNECTION=redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="onboarding@resend.dev"
MAIL_FROM_NAME="TontineSN"
RESEND_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

PAYTECH_API_KEY=
PAYTECH_API_SECRET=
PAYTECH_BASE_URL=https://paytech.sn

GREENAPI_ID_INSTANCE=
GREENAPI_API_TOKEN=
# Secret unique intégré dans l'URL webhook : https://tontinesn.com/webhooks/greenapi/{ce_secret}
# Générez-le avec : openssl rand -hex 32
# Puis configurez cette URL complète dans GreenAPI > Paramètres > Webhook URL
GREENAPI_WEBHOOK_SECRET=

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

FCM_SERVER_KEY=

# Web Push VAPID (générer avec : php artisan vapid:generate ou openssl ecparam -name prime256v1...)
# En prod AlwaysData : ssh tontinesn.alwaysdata.net "cd www && php artisan tinker --execute=\"echo json_encode(Minishlink\WebPush\VAPID::createVapidKeys());\""
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:contact@tontinesn.com"

OTP_EXPIRY_MINUTES=5
TRANSACTION_DAILY_LIMIT=500000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
