# ═══════════════════════════════════════════
# TontineSN — Variables Railway (dashboard)
# ═══════════════════════════════════════════
# Copier ces valeurs dans Railway > Variables

APP_NAME=TontineSN
APP_ENV=production
APP_DEBUG=false
# Remplacer par l'URL Railway après déploiement
APP_URL=https://tontinesn-production.up.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=warning

# 🔑 Générée avec : php artisan key:generate
# Déjà dans .env, à copier ici
APP_KEY=base64:Adv1gA6mxIZo/vuqwQ8pciWloeqMRUh9/jfP1D7qiSA=

# ═══ Base de données — Remplie automatiquement par le plugin MySQL ═══
# DB_CONNECTION, DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD
# sont injectés par Railway. Ne PAS les définir manuellement.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

QUEUE_CONNECTION=sync

CACHE_STORE=database

# ═══ Services externes (optionnels — laisser vide si pas utilisés) ═══

# PayTech — paiements Wave, Orange Money, Free Money, Carte
PAYTECH_API_KEY=a563fb6d1b4c2c5e659bd1163b91717f16605543dcab23aae679bf164e0500d2
PAYTECH_API_SECRET=1cfc412e2e3d18400a3af5694fbe136f3a26a61490ff75abf012d518f3f74324
PAYTECH_BASE_URL=https://paytech.sn

# Resend — emails transactionnels
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=onboarding@resend.dev
MAIL_FROM_NAME=TontineSN
RESEND_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://tontinesn-production.up.railway.app/auth/google/callback

# Twilio — WhatsApp
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# FCM — Notifications push
FCM_SERVER_KEY=

OTP_EXPIRY_MINUTES=5
TRANSACTION_DAILY_LIMIT=500000

# ═══ Mots de passe seed ═══
SEED_ADMIN_PASSWORD=Admin2024!
SEED_MEMBRE_PASSWORD=Membre2024!
